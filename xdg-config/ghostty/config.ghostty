theme = Dracula+

macos-titlebar-style = native
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true
window-width = 140
window-height = 40

font-family = FiraCode Nerd Font Mono
font-style = Ret
font-size = 14
font-thicken = true
font-thicken-strength = 51

shell-integration-features = no-cursor,no-sudo,no-title

keybind = super+enter=text:\n
