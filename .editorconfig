# EditorConfig: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
max_line_length = off
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,zsh}]
max_line_length = 80

[zshrc.symlink]
max_line_length = 80

# Git Config Files
[gitconfig.local.symlink.template]
max_line_length = off
indent_style = tab

[gitconfig.symlink]
max_line_length = off
indent_style = tab

[gitignore.symlink]
max_line_length = off
indent_style = tab
